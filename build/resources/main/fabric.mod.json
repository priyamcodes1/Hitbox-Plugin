{
  "schemaVersion": 1,
  "id": "customhitboxes",
  "version": "1.0.0",
  "name": "Hitbox Plus",
  "description": "A fabric mod for Hitboxes, highly configurable. Customize widths, apply dynamic combat coloring, and tailor the visual rendering pipeline to your exact specifications.",
  "authors": [
    "ItzGlecni"
  ],
  "license": "MIT",
  "icon": "assets/icon.png",
  "environment": "client",
  "entrypoints": {
    "client": [
      "itzglecni.customhitboxes.CustomHitboxes"
    ],
    "modmenu": [
      "itzglecni.customhitboxes.gui.ModMenuIntegration"
    ]
  },
  "mixins": [
    "customhitboxes.mixins.json"
  ],
  "depends": {
    "fabricloader": ">=0.18.1",
    "minecraft": "~1.21.11",
    "java": ">=21",
    "fabric-api": "*",
    "cloth-config": "*",
    "modmenu": "*"
  }
}